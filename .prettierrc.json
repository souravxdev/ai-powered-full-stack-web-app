{
   "useTabs": false,
   "tabWidth": 3,
   "trailingComma": "es5",
   "semi": true,
   "singleQuote": true,
   "printWidth": 80,
   "bracketSameLine": true,
   "overrides": [
      {
         "files": ["*.ts", "*.mts", "*.d.ts"],
         "options": { "parser": "typescript" }
      },
      { "files": ["*.html"], "options": { "parser": "html" } },
      { "files": ["*.component.html"], "options": { "parser": "angular" } }
   ]
}
